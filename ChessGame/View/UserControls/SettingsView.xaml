<UserControl x:Class="ChessGame.View.UserControls.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ChessGame.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Transparent">

        <Border Style="{StaticResource BorderStyle}" 
                Padding="25" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                Width="150"
                MinWidth="300">

            <StackPanel>
                <TextBlock Text="Налаштування" 
                           Style="{StaticResource TextStyle}" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Margin="0,0,0,20"/>

                <TextBlock Text="Роздільна здатність:" 
                           Style="{StaticResource TextStyle}" 
                           HorizontalAlignment="Left" 
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <ComboBox ItemsSource="{Binding AvailableResolutions}" 
                          SelectedItem="{Binding SelectedResolution}"
                          Style="{StaticResource ComboBoxStyle}"
                          Margin="0,0,0,15"
                          Height="35"/>

                <CheckBox Content="Повноекранний режим" 
                          IsChecked="{Binding IsFullScreen}" 
                          Foreground="{StaticResource TextColor}" 
                          FontSize="15" 
                          Margin="0,5,0,25" 
                          HorizontalAlignment="Center"
                          VerticalContentAlignment="Center"/>

                <Button Content="Застосувати" 
                        Command="{Binding ApplyCommand}" 
                        Style="{StaticResource ButtonStyle}" 
                        Margin="0,0,0,10"
                        Height="35"/>

                <Button Content="Назад" 
                        Command="{Binding BackCommand}" 
                        Style="{StaticResource ButtonStyle}" 
                        Height="35"/>
            </StackPanel>

        </Border>
    </Grid>
</UserControl>